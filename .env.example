# ── Frontend (Vite) ─────────────────────────────────────────────────────────
# Expose to browser with VITE_ prefix.
# On Vercel: set these in Project → Settings → Environment Variables

# Leave empty to use the built-in mock/simulation (works with no backend)
VITE_API_BASE=
VITE_WS_BASE=

# Set to "true" to force simulation mode even if API base is set
VITE_SIMULATE=true
